{
  "name": "state-management-libs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "lint": "oxfmt --check && oxlint",
    "lint:fix": "oxfmt && oxlint --fix",
    "preview": "vite preview",
    "spell": "cspell --no-progress --no-summary \"**/*.{ts,tsx,js,jsx,md,json,css,html}\"",
    "validate": "pnpm run spell && pnpm run lint"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-router": "^1.168.23",
    "antd": "^6.3.6",
    "clsx": "^2.1.1",
    "image-js": "^1.5.0",
    "jotai": "^2.19.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "valibot": "^1.3.1",
    "valtio": "^2.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cspell": "^9.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.9"
  }
}
